<view class="container" wx:if="{{term}}">
  <view class="card">
    <view class="en">{{term.termEn}}</view>
    <view class="cn text-sub">{{term.termCn}}</view>
    <view class="cat text-gold">{{categoryLabel[term.category]}}</view>
  </view>
  <view class="card">
    <view class="title">释义</view>
    <view>{{term.definition}}</view>
  </view>
  <view class="card" wx:if="{{term.example}}">
    <view class="title">例子</view>
    <view class="text-sub">{{term.example}}</view>
  </view>

  <!-- 生动释义（数据规则生成） -->
  <view class="card ai-card" wx:if="{{!aiText && !aiLoading}}" bindtap="onAskAi">
    <view class="ai-hero">
      <text class="ai-emoji">🤖</text>
      <view>
        <view class="ai-title">给我一个生动版</view>
        <view class="text-sub">场景化讲透 + 实战体感</view>
      </view>
    </view>
  </view>

  <view class="card" wx:elif="{{aiLoading}}">
    <view class="ai-loading">
      <text class="brain">🧠</text>
      <text class="text-sub">正在生成…</text>
    </view>
  </view>

  <view class="card ai-result" wx:elif="{{aiText}}">
    <view class="ai-header">
      <text class="ai-tag">💡 生动版</text>
      <view class="ai-actions">
        <text bindtap="onCopyAi" class="text-sub op-btn">复制</text>
        <text bindtap="onAskAi" class="text-sub op-btn">换一段</text>
      </view>
    </view>
    <view class="ai-body">{{aiText}}</view>
  </view>

  <view class="card text-danger" wx:if="{{aiError}}" bindtap="onAskAi">
    <text>{{aiError}}，点击重试</text>
  </view>
</view>
<view wx:elif="{{!loading}}" class="text-sub" style="padding:120rpx;text-align:center;">未找到该术语</view>
