.empty {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 32rpx; gap: 16rpx;
}
.empty .icon { width: 240rpx; height: 240rpx; opacity: 0.7; }
.empty .title { font-size: 30rpx; color: var(--text); margin-top: 16rpx; }
.empty .desc { text-align: center; max-width: 480rpx; }
.empty .btn { margin-top: 32rpx; }
