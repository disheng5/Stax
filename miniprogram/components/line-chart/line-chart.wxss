.chart-root { width: 100%; position: relative; box-sizing: border-box; }

.chart-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.chart-empty-text { font-size: 24rpx; }

.chart-body { width: 100%; position: relative; overflow: visible; }

.grid-line {
  position: absolute;
  left: 72rpx;
  right: 8rpx;
  height: 1rpx;
  background: rgba(0, 0, 0, 0.06);
}

.bar {
  position: absolute;
  border-radius: 3rpx 3rpx 0 0;
}

.y-label {
  position: absolute;
  right: calc(100% - 68rpx);
  transform: translateY(-50%);
  font-size: 18rpx;
  color: #999;
  white-space: nowrap;
  text-align: right;
  width: 64rpx;
}

.seg {
  position: absolute;
  height: 3rpx;
  transform-origin: 0 50%;
  border-radius: 2rpx;
}

.dot {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  border: 2rpx solid #fff;
}

.x-label {
  position: absolute;
  bottom: 0;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: #bbb;
  white-space: nowrap;
}
