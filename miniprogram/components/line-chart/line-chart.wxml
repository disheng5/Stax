<view class="chart-root" style="height:{{height}}px;">
  <view wx:if="{{empty}}" class="chart-empty">
    <text class="chart-empty-text">暂无数据，打完第一局就能看到趋势</text>
  </view>
  <view wx:else class="chart-body" style="height:{{height}}px;">
    <view class="y-label" wx:for="{{yLabels}}" wx:key="label"
      style="top:{{item.top}};">{{item.label}}</view>
    <view class="seg" wx:for="{{segments}}" wx:key="index"
      style="left:{{item.left}};top:{{item.top}};width:{{item.width}};transform:rotate({{item.angle}}deg);background:{{item.color}};"></view>
    <view class="dot" wx:for="{{dots}}" wx:key="index"
      style="left:{{item.left}};top:{{item.top}};background:{{item.color}};"></view>
    <view class="x-label" wx:for="{{xLabels}}" wx:key="i"
      style="left:{{item.left}};">{{item.label}}</view>
  </view>
</view>
