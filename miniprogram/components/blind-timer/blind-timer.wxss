.timer-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--table-green);
  color: #fff;
  padding: 24rpx 32rpx;
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
}
.level { font-size: 26rpx; opacity: 0.85; }
.blinds { font-size: 36rpx; font-weight: 600; }
.countdown { font-size: 40rpx; font-family: 'Courier New', monospace; font-weight: 600; }
.countdown.paused { opacity: 0.5; }
