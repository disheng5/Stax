.player-card {
  background: var(--card);
  border-bottom: 2rpx solid var(--border);
  padding: 18rpx 0;
}

.player-card:last-child {
  border-bottom: none;
}

.player-card.eliminated {
  opacity: 0.55;
}

.player-card.me {
  background: rgba(43, 108, 176, 0.04);
  margin: 0 -24rpx;
  padding: 18rpx 24rpx;
}

.main-row {
  display: grid;
  grid-template-columns: 1fr 80rpx 120rpx 120rpx;
  align-items: center;
  gap: 8rpx;
}

.player-cell {
  display: flex;
  align-items: center;
  min-width: 0;
}

.avatar {
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--border);
}

.name-wrap {
  min-width: 0;
  margin-left: 14rpx;
  flex: 1;
}

.nickname {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 26rpx;
  font-weight: 500;
}

.me-tag {
  display: inline-block;
  margin-left: 8rpx;
  padding: 1rpx 8rpx;
  background: var(--table-green);
  color: #fff;
  font-size: 18rpx;
  border-radius: 6rpx;
  vertical-align: middle;
}

.status {
  margin-top: 4rpx;
  font-size: 21rpx;
  line-height: 1.4;
}

.metric,
.profit {
  text-align: right;
  font-size: 26rpx;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profit {
  font-weight: 700;
}
