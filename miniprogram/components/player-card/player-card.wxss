.player-card {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  background: var(--card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
}
.player-card.eliminated { opacity: 0.55; }
.player-card.me { border: 2rpx solid var(--table-green); }
.avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: var(--border); }
.info { flex: 1; }
.nickname { font-size: 30rpx; font-weight: 500; }
.me-tag { display: inline-block; margin-left: 8rpx; padding: 2rpx 10rpx; background: var(--table-green); color: #fff; font-size: 20rpx; border-radius: 8rpx; }
.stats { margin-top: 6rpx; }
.stack { font-size: 36rpx; font-weight: 600; color: var(--gold); }
.actions { width: 100%; display: flex; gap: 12rpx; margin-top: 12rpx; }
.btn-sm { height: 60rpx; padding: 0 20rpx; font-size: 24rpx; flex: 1; line-height: 60rpx; }
