<view class="player-card {{player.eliminatedAt ? 'eliminated' : ''}} {{isSelf ? 'me' : ''}}" bindtap="onTap">
  <view class="main-row">
    <view class="player-cell">
      <image class="avatar" src="{{player.avatar || '/images/default-avatar.png'}}" />
      <view class="name-wrap">
        <view class="nickname">{{player.nickname}}<text class="me-tag" wx:if="{{isSelf}}">我</text></view>
        <view class="text-sub status" wx:if="{{player.finalStack !== null && player.finalStack !== undefined}}">已结算</view>
        <view class="text-sub status" wx:elif="{{player.eliminatedAt}}">已踢出</view>
        <view class="text-sub status" wx:else>进行中</view>
      </view>
    </view>
    <view class="metric">{{player.buyInCount}}</view>
    <view class="metric">{{player.totalBuyIn}}</view>
    <view class="profit text-success" wx:if="{{player.finalStack !== null && player.finalStack !== undefined && player.profit >= 0}}">+{{player.profit}}</view>
    <view class="profit text-danger" wx:elif="{{player.finalStack !== null && player.finalStack !== undefined}}">{{player.profit}}</view>
    <view class="profit text-sub" wx:else>未结</view>
  </view>
</view>
