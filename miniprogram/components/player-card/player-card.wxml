<view class="player-card {{player.eliminatedAt ? 'eliminated' : ''}} {{isSelf ? 'me' : ''}} {{gameStatus === 'ended' ? 'ended' : ''}}" bindtap="onTap">
  <view class="main-row">
    <view class="player-cell">
      <view class="avatar-wrap">
        <image class="avatar" src="{{player.displayAvatar || '/images/default-avatar.png'}}" mode="aspectFill" fade-in="{{false}}" />
        <view class="crown" wx:if="{{isWinner && gameStatus === 'ended'}}"></view>
      </view>
      <view class="name-wrap">
        <view class="nickname">{{player.nickname}}<text class="me-tag" wx:if="{{isSelf}}">我</text></view>
      </view>
    </view>
    <view class="metric" wx:if="{{player.seat}}">{{player.seat}}号</view>
    <view class="metric text-sub" wx:else>--</view>
    <view class="metric">{{player.buyInCount}}</view>
    <view class="metric" wx:if="{{player.finalStack !== null && player.finalStack !== undefined}}">{{player.finalStack}}</view>
    <view class="metric text-sub" wx:else>--</view>
    <view class="profit text-gain" wx:if="{{player.finalStack !== null && player.finalStack !== undefined && player.profit > 0}}">+{{player.profit}}</view>
    <view class="profit text-sub" wx:elif="{{player.finalStack !== null && player.finalStack !== undefined && player.profit === 0}}">0</view>
    <view class="profit text-loss" wx:elif="{{player.finalStack !== null && player.finalStack !== undefined}}">{{player.profit}}</view>
    <view class="profit-action" wx:elif="{{gameStatus === 'ongoing'}}">
      <text class="action-text">未结算</text>
      <text class="action-arrow">></text>
    </view>
    <view class="profit text-sub" wx:else>--</view>
  </view>
</view>
