.chip-input { margin: 16rpx 0; }
.label { font-size: 26rpx; color: var(--text-sub); margin-bottom: 8rpx; }
.row { display: flex; align-items: center; gap: 12rpx; }
.step {
  width: 72rpx; height: 72rpx; border-radius: var(--radius-sm);
  background: var(--border); color: var(--text); font-size: 36rpx;
  display: flex; align-items: center; justify-content: center; padding: 0; line-height: 1;
}
.num {
  flex: 1; height: 72rpx; padding: 0 20rpx;
  background: var(--card); border: 2rpx solid var(--border);
  border-radius: var(--radius-sm); font-size: 32rpx; text-align: center;
}
