/* theme.wxss — 主题色与设计令牌 (Spec §1) */
page {
  --table-green: #2B6CB0;
  --chip-red: #c8102e;
  --gold: #c9a961;
  --bg: #F7F9FC;
  --card: #ffffff;
  --text: #1a1a1a;
  --text-sub: #666666;
  --border: #E2E8F0;
  --danger: #c8102e;
  --success: #2B6CB0;
  /* 盈亏语义色：盈利红、亏损绿（A股涨红跌绿约定），与状态色 success/danger 区分 */
  --gain: #c8102e;
  --loss: #2e9d5b;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --shadow-card: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 40rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 500;
  background: var(--table-green);
  color: #ffffff;
  border: none;
}

.btn--primary { background: var(--table-green); color: #fff; }
.btn--danger  { background: var(--chip-red);   color: #fff; }
.btn--ghost   { background: transparent;        color: var(--table-green); border: 2rpx solid var(--table-green); }
.btn--block   { width: 100%; }

.btn:active { opacity: 0.85; }
.btn[disabled] { opacity: 0.5; }

.card {
  background: var(--card);
  border-radius: var(--radius-md);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.text-sub { color: var(--text-sub); font-size: 24rpx; line-height: 1.55; }
.text-gold { color: var(--gold); }
.text-danger { color: var(--danger); }
.text-success { color: var(--success); }
.text-gain { color: var(--gain); }
.text-loss { color: var(--loss); }

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 骨架屏（加载占位，全局可用） */
.sk {
  position: relative;
  overflow: hidden;
  background: #e6ebf2;
  border-radius: var(--radius-sm);
}
.sk::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  transform: translateX(-100%);
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.65) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  animation: sk-shimmer 1.2s infinite;
}
@keyframes sk-shimmer {
  100% {
    transform: translateX(100%);
  }
}
.sk-card {
  background: var(--card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.sk-row {
  display: flex;
  align-items: center;
}
.sk-row .sk-avatar {
  margin-right: 20rpx;
}
.sk-flex {
  flex: 1;
}
.sk-line {
  height: 28rpx;
  margin-bottom: 16rpx;
}
.sk-line:last-child {
  margin-bottom: 0;
}
.sk-w-20 { width: 20%; }
.sk-w-40 { width: 40%; }
.sk-w-60 { width: 60%; }
.sk-w-80 { width: 80%; }
.sk-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
