<view class="container">
  <view wx:if="{{demoMode}}" class="demo-banner">
    🧪 Demo 模式 · 数据保存在内存中、刷新即重置 · 真实环境请配置 envId
  </view>

  <view wx:if="{{firstTime}}" class="first-time-banner">
    <view class="first-time-title">欢迎使用 StaxKit</view>
    <view class="first-time-desc">设置头像和昵称，让好友认识你</view>
  </view>

  <view class="card user">
    <button class="avatar-wrap" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar" src="{{avatarDisplayUrl}}" mode="aspectFill" fade-in="{{false}}" />
      <view class="avatar-tip text-sub">点击更换头像</view>
    </button>
    <view class="nickname-row">
      <text class="label">昵称</text>
      <input class="nickname-input" type="nickname" value="{{nickname}}" placeholder="点击输入微信昵称" bindinput="onNicknameInput" />
    </view>
    <button class="btn btn--primary btn--block" wx:if="{{editing}}" bindtap="onSaveProfile">保存资料</button>
  </view>

  <view class="stat-grid">
    <view class="stat-item"><view class="num">{{stats.totalGames}}</view><view class="text-sub">总场次</view></view>
    <view class="stat-item"><view class="num {{stats.totalProfit > 0 ? 'text-gain' : stats.totalProfit < 0 ? 'text-loss' : ''}}">{{stats.totalProfit > 0 ? '+' : ''}}{{stats.totalProfit}}</view><view class="text-sub">累计盈亏</view></view>
    <view class="stat-item"><view class="num">{{stats.winRate}}%</view><view class="text-sub">胜率</view></view>
  </view>

  <view class="card row" bindtap="onHistory">
    <text>战绩 & 分析</text><text class="text-sub">›</text>
  </view>

  <view class="section-title">常用工具</view>
  <view class="card row" bindtap="onLearnTerms">
    <text>术语词典</text><text class="text-sub">›</text>
  </view>
  <view class="card row" bindtap="onLearnHandChart">
    <text>起手参考</text><text class="text-sub">›</text>
  </view>
  <view class="card row" bindtap="onLearnOdds">
    <text>概率计算器</text><text class="text-sub">›</text>
  </view>
  <view class="card row" bindtap="onLearnRules">
    <text>规则速览</text><text class="text-sub">›</text>
  </view>

  <view class="section-title">设置</view>
  <view wx:if="{{demoMode}}" class="card row" bindtap="onResetDemo">
    <text class="text-gold">🧪 重置 Demo 数据</text><text class="text-sub">›</text>
  </view>
  <view class="card row" bindtap="onAbout">
    <text>关于 StaxKit</text><text class="text-sub">›</text>
  </view>
</view>
