.user { display: flex; align-items: center; gap: 24rpx; padding: 32rpx; }
.user .avatar { width: 120rpx; height: 120rpx; border-radius: 50%; background: var(--border); }
.user .nick { font-size: 32rpx; font-weight: 600; }
.row { display: flex; justify-content: space-between; align-items: center; padding: 32rpx; }
