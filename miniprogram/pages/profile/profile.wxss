.user { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 40rpx 32rpx; }

.avatar-wrap {
  background: transparent; border: none; padding: 0; margin: 0; line-height: 1;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.avatar-wrap::after { border: none; }
.avatar { width: 140rpx; height: 140rpx; border-radius: 50%; background: var(--border); }
.avatar-tip { font-size: 22rpx; }

.nickname-row { display: flex; align-items: center; gap: 16rpx; width: 100%; padding: 16rpx 0; border-bottom: 2rpx solid var(--border); }
.nickname-row .label { font-size: 26rpx; color: var(--text-sub); }
.nickname-input { flex: 1; height: 64rpx; font-size: 30rpx; }

.row { display: flex; justify-content: space-between; align-items: center; padding: 32rpx; }
.stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; margin-bottom: 24rpx; }
.stat-item { background: var(--card); border-radius: var(--radius-md); padding: 24rpx 16rpx; text-align: center; box-shadow: var(--shadow-card); }
.stat-item .num { font-size: 36rpx; font-weight: 700; margin-bottom: 6rpx; }
