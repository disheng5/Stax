<view class="container" wx:if="{{loading && !circle}}">
  <view class="sk-card">
    <view class="sk sk-line sk-w-40" style="height: 36rpx;"></view>
    <view class="sk sk-line sk-w-20"></view>
  </view>
  <view class="sk-card">
    <view class="sk-row" style="margin-bottom: 20rpx;" wx:for="{{[1, 2, 3]}}" wx:key="*this">
      <view class="sk sk-avatar" style="width: 48rpx; height: 48rpx;"></view>
      <view class="sk-flex">
        <view class="sk sk-line sk-w-60" style="margin-bottom: 0;"></view>
      </view>
    </view>
  </view>
</view>
<view class="container" wx:if="{{circle}}">
  <view class="header card">
    <view class="header-top">
      <view class="circle-name">{{circle.name}}</view>
      <button class="share-chip" open-type="share">邀请好友</button>
    </view>
    <view class="header-meta text-sub">
      <text>{{circle.memberOpenids.length}} 人</text>
    </view>
  </view>

  <view class="season-block card" wx:if="{{season}}">
    <view class="season-header">
      <view class="season-header-left">
        <view class="season-name">{{season.seasonName}}</view>
        <view class="season-remain text-sub">剩 {{daysLeft}} 天</view>
      </view>
      <view class="season-history" wx:if="{{season.seasonNo > 1}}" bindtap="onHistory">前贤录 ›</view>
    </view>

    <view class="block-divider"></view>

    <!-- 荣誉前三：只露头像/昵称/名次 -->
    <view wx:if="{{honors.length}}">
      <view class="rank-item" wx:for="{{honors}}" wx:key="openid">
        <view class="rank-badge rank-{{item.rank <= 3 ? item.rank : 'n'}}">{{item.rank}}</view>
        <view class="rank-avatar-wrap">
          <view class="rank-crown" wx:if="{{item.rank === 1}}"></view>
          <image class="rank-avatar" src="{{item.displayAvatar || '/images/default-avatar.png'}}" mode="aspectFill" fade-in="{{false}}" />
        </view>
        <view class="rank-info">
          <view class="rank-name rank-name-{{item.rank <= 3 ? item.rank : 'n'}}">{{item.nickname}}</view>
        </view>
      </view>
    </view>
    <view class="empty-rank" wx:else>
      <text class="text-sub">赛季刚开始，快来打第一场吧</text>
    </view>

    <!-- 我的赛季：仅本人可见自己的名次/胜率/场次 -->
    <view wx:if="{{me}}">
      <view class="block-divider"></view>
      <view class="my-season">
        <view class="my-season-title text-sub">我的赛季</view>
        <view class="my-season-row">
          <view class="my-season-cell">
            <view class="my-season-num">{{me.rank > 0 ? me.rank : '-'}}</view>
            <view class="my-season-label text-sub">名次</view>
          </view>
          <view class="my-season-cell">
            <view class="my-season-num">{{me.games}}</view>
            <view class="my-season-label text-sub">场次</view>
          </view>
          <view class="my-season-cell">
            <view class="my-season-num">{{me.winRate}}%</view>
            <view class="my-season-label text-sub">胜率</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 成员：只露头像/昵称 -->
    <view wx:if="{{members.length}}">
      <view class="block-divider"></view>
      <view class="games-header">
        <text class="games-label text-sub">成员 {{members.length}} 人</text>
      </view>
      <view class="member-grid">
        <view class="member-chip" wx:for="{{members}}" wx:key="openid" data-openid="{{item.openid}}" data-name="{{item.nickname}}" bindtap="onRankTap">
          <image class="member-avatar" src="{{item.displayAvatar || '/images/default-avatar.png'}}" mode="aspectFill" fade-in="{{false}}" />
          <text class="member-name">{{item.nickname}}</text>
        </view>
      </view>
    </view>

    <!-- 我的记录：本人参与且计入的记录 -->
    <view wx:if="{{myGames.length}}">
      <view class="block-divider"></view>
      <view class="games-header">
        <text class="games-label text-sub">我的记录 {{myGames.length}} 场</text>
      </view>
      <view class="season-game" wx:for="{{myGames}}" wx:key="_id" data-id="{{item._id}}" bindtap="onOpenGame">
        <view class="sg-left">
          <view class="sg-name">{{item.name || 'StaxKit 记录'}}</view>
          <view class="sg-meta text-sub">{{item.playerCount}} 人 · {{item.dateStr}} · {{item.durationStr}}</view>
        </view>
        <view class="sg-right {{item.myProfit >= 0 ? 'profit-up' : 'profit-down'}}">{{item.myProfit >= 0 ? '+' : ''}}{{item.myProfit}}</view>
      </view>
    </view>

    <!-- 榜主复盘：仅 owner，只含短号/时间/人数/时长/合规，可排除/恢复 -->
    <view wx:if="{{isOwner && ownerReview.length}}">
      <view class="block-divider"></view>
      <view class="games-header">
        <text class="games-label text-sub">榜主复盘 · 本赛季 {{seasonCount}} 场</text>
      </view>
      <view class="season-game {{item.excluded ? 'excluded' : ''}}" wx:for="{{ownerReview}}" wx:key="_id">
        <view class="sg-left">
          <view class="sg-name">#{{item.shortId}} <text class="text-sub">{{item.compliant ? '' : '· 未达门槛'}}</text></view>
          <view class="sg-meta text-sub">{{item.playerCount}} 人 · {{item.dateStr}} · {{item.durationStr}}</view>
        </view>
        <view class="sg-chip {{item.excluded ? 'restore' : 'exclude'}}" catchtap="onToggleSeasonGame" data-id="{{item._id}}" data-excluded="{{item.excluded}}">{{item.excluded ? '恢复' : '排除'}}</view>
      </view>
    </view>
  </view>

  <view class="season-block card" wx:else>
    <view class="empty-rank">
      <text class="text-sub">赛季未启动，打一场合规局即可开启（≥4人、≥20分钟）</text>
    </view>
  </view>

  <view class="footer-actions">
    <view class="footer-link" wx:if="{{!isOwner}}" bindtap="onLeave">退出积分榜</view>
    <view wx:if="{{isOwner}}" class="owner-actions">
      <view class="footer-link" wx:if="{{season}}" bindtap="onResetSeason">重置本季积分</view>
      <view class="footer-link danger" bindtap="onDissolve">解散积分榜</view>
    </view>
  </view>
</view>
