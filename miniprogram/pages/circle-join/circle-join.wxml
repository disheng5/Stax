<view class="container invite-page">
  <view class="invite-card">
    <view class="invite-mark">榜</view>
    <view class="invite-title">{{status === 'joining' ? '正在加入积分榜' : '邀请暂不可用'}}</view>
    <view class="invite-note text-sub">{{message}}</view>
    <view class="invite-loading" wx:if="{{status === 'joining'}}"></view>
    <button class="btn btn--ghost btn--block" wx:else bindtap="onBack">返回积分榜</button>
  </view>
</view>
