.label {
  margin-bottom: 12rpx;
  color: var(--text-sub);
  font-size: 26rpx;
}

.sub-label {
  margin-bottom: 8rpx;
  color: var(--text-sub);
  font-size: 23rpx;
}

.text-input,
.amount-input,
.small-input {
  height: 80rpx;
  padding: 0 22rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  background: #fff;
  box-sizing: border-box;
  font-size: 28rpx;
}

.text-input {
  width: 100%;
}

.amount-input {
  width: 100%;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--table-green);
}

.row-input {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.small-input {
  width: 100%;
  text-align: center;
}

.permission-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.permission-card > view:first-child {
  flex: 1;
  min-width: 0;
}

.ratio-card {
  padding-bottom: 28rpx;
}

.ratio-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.ratio-head .label {
  margin-bottom: 0;
}

.ratio-picker {
  flex-shrink: 0;
}

.ratio-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(11, 110, 79, 0.1);
  color: var(--table-green);
  font-size: 28rpx;
  font-weight: 600;
}

.ratio-tag .arrow {
  font-size: 28rpx;
  line-height: 1;
  opacity: 0.55;
  transform: translateY(-2rpx);
}

.ratio-hint {
  margin-top: 16rpx;
  font-size: 23rpx;
  line-height: 1.5;
}
