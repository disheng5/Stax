.label { font-size: 26rpx; color: var(--text-sub); margin-bottom: 12rpx; }
.text-input {
  height: 72rpx; padding: 0 20rpx; background: #fff;
  border: 2rpx solid var(--border); border-radius: var(--radius-sm);
}
.presets { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.preset {
  flex: 1; text-align: center; padding: 20rpx 0;
  border: 2rpx solid var(--border); border-radius: var(--radius-sm);
  font-size: 26rpx; color: var(--text-sub);
}
.preset.active { border-color: var(--table-green); color: var(--table-green); background: rgba(11,110,79,0.08); }
