.create-page {
  padding-top: 24rpx;
}

.purpose-strip {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid rgba(43, 108, 176, 0.16);
  border-radius: var(--radius-md);
  background: rgba(43, 108, 176, 0.07);
}

.purpose-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
  border-radius: var(--radius-sm);
  background: var(--table-green);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.purpose-copy {
  min-width: 0;
}

.purpose-title {
  color: var(--text);
  font-size: 27rpx;
  font-weight: 600;
}

.purpose-note {
  margin-top: 2rpx;
  color: var(--text-sub);
  font-size: 22rpx;
}

.form-panel {
  padding: 28rpx;
  border-radius: var(--radius-md);
  background: #fff;
  box-shadow: var(--shadow-card);
}

.field {
  margin-bottom: 28rpx;
}

.field--compact {
  min-width: 0;
  margin-bottom: 0;
}

.field-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: var(--text-sub);
  font-size: 24rpx;
}

.field-caption {
  color: #8a94a3;
  font-size: 20rpx;
  white-space: nowrap;
}

.text-input,
.amount-input,
.small-input {
  width: 100%;
  height: 76rpx;
  padding: 0 20rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  background: #fff;
  box-sizing: border-box;
  color: var(--text);
  font-size: 28rpx;
}

.amount-input {
  color: var(--table-green);
  font-size: 36rpx;
  font-weight: 700;
}

.small-input {
  text-align: center;
  font-weight: 600;
}

.preset-control {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
  padding: 6rpx;
  border-radius: var(--radius-sm);
  background: #eef2f7;
}

.preset-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 62rpx;
  border-radius: 6rpx;
  color: var(--text-sub);
  font-size: 22rpx;
  font-weight: 500;
  white-space: nowrap;
}

.preset-item--active {
  background: #fff;
  color: var(--table-green);
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(24, 52, 82, 0.12);
}

.blind-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.advanced-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 68rpx;
  padding-top: 8rpx;
  border-top: 2rpx solid var(--border);
  color: var(--text);
  font-size: 25rpx;
}

.advanced-action {
  display: flex;
  align-items: center;
  color: var(--table-green);
  font-size: 23rpx;
}

.advanced-arrow {
  margin-left: 8rpx;
  font-size: 30rpx;
  line-height: 1;
  transform: rotate(90deg);
}

.advanced-arrow--open {
  transform: rotate(-90deg);
}

.advanced-body {
  border-top: 2rpx solid var(--border);
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 108rpx;
  border-bottom: 2rpx solid var(--border);
}

.setting-row--last {
  border-bottom: 0;
}

.setting-copy {
  min-width: 0;
}

.setting-title {
  font-size: 25rpx;
  font-weight: 500;
}

.setting-note {
  margin-top: 4rpx;
  color: var(--text-sub);
  font-size: 21rpx;
}

.ratio-value {
  padding: 10rpx 16rpx;
  border-radius: var(--radius-sm);
  background: rgba(43, 108, 176, 0.09);
  color: var(--table-green);
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.create-button {
  margin-top: 24rpx;
}
