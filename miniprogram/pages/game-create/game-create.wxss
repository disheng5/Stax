.label {
  margin-bottom: 12rpx;
  color: var(--text-sub);
  font-size: 26rpx;
}

.sub-label {
  margin-bottom: 8rpx;
  color: var(--text-sub);
  font-size: 23rpx;
}

.text-input,
.amount-input,
.small-input {
  height: 76rpx;
  padding: 0 20rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  background: #fff;
  box-sizing: border-box;
}

.text-input {
  width: 100%;
}

.amount-input {
  width: 100%;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--table-green);
}

.row-input {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.small-input {
  width: 100%;
  text-align: center;
}

.permission-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}
