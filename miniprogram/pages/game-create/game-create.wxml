<view class="container">
  <view class="card">
    <view class="label">局名</view>
    <input class="text-input" value="{{name}}" bindinput="onNameInput" />
  </view>

  <view class="card">
    <view class="label">每手码量</view>
    <input class="amount-input" type="digit" value="{{buyIn}}" bindinput="onBuyInInput" />
  </view>

  <view class="card">
    <view class="label">大小盲</view>
    <view class="row-input">
      <view>
        <view class="sub-label">小盲</view>
        <input class="small-input" type="digit" value="{{smallBlind}}" bindinput="onSbInput" />
      </view>
      <view>
        <view class="sub-label">大盲</view>
        <input class="small-input" type="digit" value="{{bigBlind}}" bindinput="onBbInput" />
      </view>
    </view>
  </view>

  <view class="card permission-card">
    <view>
      <view class="label">权限共享</view>
      <view class="text-sub">允许玩家自己补码、自己结算下桌</view>
    </view>
    <switch checked="{{playerOpsShared}}" bindchange="onPlayerOpsSharedChange" color="#0B6E4F" />
  </view>

  <button class="btn btn--primary btn--block" bindtap="onSubmit" disabled="{{submitting}}">开局</button>
</view>
