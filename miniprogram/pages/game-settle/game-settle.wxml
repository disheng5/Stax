<view class="container" wx:if="{{game}}">
  <view class="settle-poster card" wx:if="{{settleImagePath}}">
    <view class="title">结算图</view>
    <image class="poster-image" src="{{settleImagePath}}" mode="widthFix" />
    <view class="poster-actions">
      <button class="btn btn--primary" open-type="share">分享结算图</button>
      <button class="btn btn--ghost" bindtap="onSaveImage">保存相册</button>
    </view>
  </view>

  <view class="card progress-card">
    <view class="title">下桌结算</view>
    <view class="text-sub" wx:if="{{!isHost}}">填写手头积分，提交后所有人可见差额。</view>
    <view class="text-sub" wx:elif="{{!allSettled}}">所有人填完积分后自动收局。</view>
    <view class="text-sub" wx:else>所有人已提交。</view>
  </view>

  <view class="card {{submitted ? 'muted-card' : ''}}">
    <view class="title">手头积分</view>
    <view class="row" wx:for="{{playerProfits}}" wx:key="openid">
      <view class="name-col">
        <view class="name">{{item.nickname}}</view>
        <view class="text-sub">买了 {{item.buyInCount}} 手 · 总积分 {{item.totalBuyIn}}</view>
      </view>
      <input class="num" type="digit" data-openid="{{item.openid}}" value="{{finalStacks[item.openid]}}" bindinput="onStackInput" disabled="{{false}}" placeholder="待填" />
      <view wx:if="{{item.hasFinal}}" class="profit {{item.profit > 0 ? 'text-gain' : item.profit < 0 ? 'text-loss' : 'text-sub'}}">{{item.profit > 0 ? '+' : ''}}{{item.profit}}</view>
      <view wx:else class="profit text-sub">待下桌</view>
    </view>
  </view>

  <view class="card {{diff !== 0 && allSettled ? 'warn' : ''}}">
    <view>差额 = <text class="{{diff === 0 ? 'text-success' : 'text-danger'}}">{{diff > 0 ? '+' : ''}}{{diff}}</text>
      <text wx:if="{{diff === 0 && allSettled}}" class="text-success"> 水平</text>
    </view>
    <view class="text-sub" wx:if="{{!allSettled}}">等所有玩家填写后自动检查</view>
  </view>

  <view class="card {{submitted ? 'muted-card' : ''}}" wx:if="{{isHost}}">
    <view class="title">其他费用（可选）</view>
    <view class="text-sub" style="margin-bottom:12rpx;">仅记录分摊，不影响每人盈亏积分。</view>
    <view class="row aa-row">
      <text class="label">总额</text>
      <input class="num" type="digit" placeholder="0" value="{{extraCost || ''}}" bindinput="onExtraCostInput" />
    </view>
    <view class="presets" wx:if="{{extraCost > 0}}">
      <view class="preset {{expenseMode === 'all' ? 'active' : ''}}" data-k="all" bindtap="onExpenseModeChange">全员AA</view>
      <view class="preset {{expenseMode === 'winner' ? 'active' : ''}}" data-k="winner" bindtap="onExpenseModeChange">水上按比例</view>
    </view>
    <view wx:if="{{extraCost > 0}}" style="margin-top:16rpx;">
      <view class="share-row" wx:for="{{shares}}" wx:key="openid">
        <text class="text-sub">{{item.nickname}}</text>
        <text class="text-gold">-{{item.share}}</text>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{allSettled && transfers.length}}">
    <view class="title">清算建议（{{transfers.length}} 笔）</view>
    <view class="transfer" wx:for="{{transfers}}" wx:key="index">
      <text>{{item.from}}</text>
      <text class="arrow">→</text>
      <text>{{item.to}}</text>
      <text class="amount text-gold">{{item.amount}}</text>
    </view>
  </view>
  <view class="card" wx:elif="{{allSettled && diff === 0}}">
    <view class="text-sub">无需转账</view>
  </view>

  <view class="actions" wx:if="{{!submitted}}">
    <button class="btn btn--primary btn--block" bindtap="onSubmit" disabled="{{submitting}}">
      提交积分
    </button>
  </view>

  <button wx:if="{{submitted}}" class="btn btn--ghost btn--block ai-btn" bindtap="onOpenReview">数据小结</button>

</view>

<canvas type="2d" id="settle-canvas" style="width:360px;height:900px;position:fixed;left:-9999px;top:0;"></canvas>
