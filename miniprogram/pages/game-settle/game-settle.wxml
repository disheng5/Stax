<view class="container" wx:if="{{game}}">
  <view class="card">
    <view class="title">输入每位玩家的最终筹码</view>
    <view class="row" wx:for="{{playerProfits}}" wx:key="openid">
      <view class="name-col">
        <view class="name">{{item.nickname}}</view>
        <view class="text-sub">买入 {{item.totalBuyIn}}</view>
      </view>
      <input class="num" type="digit" data-openid="{{item.openid}}" value="{{finalStacks[item.openid]}}" bindinput="onStackInput" />
      <view class="profit {{item.profit > 0 ? 'text-success' : item.profit < 0 ? 'text-danger' : 'text-sub'}}">{{item.profit > 0 ? '+' : ''}}{{item.profit}}</view>
    </view>
  </view>

  <view class="card {{diff !== 0 ? 'warn' : ''}}">
    <view>Σ profit = <text class="{{diff === 0 ? 'text-success' : 'text-danger'}}">{{diff > 0 ? '+' : ''}}{{diff}}</text></view>
    <view class="text-sub" wx:if="{{diff !== 0}}">需为 0 才能提交结算</view>
  </view>

  <!-- AA 分摊 -->
  <view class="card">
    <view class="title">额外费用 AA（可选）</view>
    <view class="text-sub" style="margin-bottom:12rpx;">用于场地 / 酒水 / 口粮 等顺场费用</view>
    <view class="row aa-row">
      <text class="label">总额</text>
      <input class="num" type="digit" placeholder="0" value="{{extraCost || ''}}" bindinput="onExtraCostInput" />
    </view>
    <view class="presets" wx:if="{{extraCost > 0}}">
      <view class="preset {{aaMode === 'even' ? 'active' : ''}}" data-k="even" bindtap="onAaModeChange">人均 AA</view>
      <view class="preset {{aaMode === 'winnerByRatio' ? 'active' : ''}}" data-k="winnerByRatio" bindtap="onAaModeChange">赢家按比例</view>
      <view class="preset {{aaMode === 'none' ? 'active' : ''}}" data-k="none" bindtap="onAaModeChange">不分摊</view>
    </view>
    <view wx:if="{{extraCost > 0 && aaMode !== 'none'}}" style="margin-top:16rpx;">
      <view class="share-row" wx:for="{{shares}}" wx:key="openid">
        <text class="text-sub">{{item.nickname}}</text>
        <text class="text-gold">-{{item.share}}</text>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{transfers.length}}">
    <view class="title">清算建议（{{transfers.length}} 笔转账）</view>
    <view class="transfer" wx:for="{{transfers}}" wx:key="index">
      <text>{{item.from}}</text>
      <text class="arrow">→</text>
      <text>{{item.to}}</text>
      <text class="amount text-gold">{{item.amount}}</text>
    </view>
  </view>
  <view class="card" wx:elif="{{canSubmit}}">
    <view class="text-sub">无需转账</view>
  </view>

  <view class="actions">
    <button class="btn btn--ghost"   bindtap="onSaveImage" disabled="{{!canSubmit}}">生成结算图</button>
    <button class="btn btn--primary" bindtap="onSubmit"    disabled="{{!canSubmit || submitting || submitted}}">{{submitted ? '已结算' : '提交结算'}}</button>
  </view>

  <button wx:if="{{submitted}}" class="btn btn--ghost btn--block ai-btn" bindtap="onAIReview">
    🤖 看看 AI 怎么点评今晚
  </button>
</view>

<canvas type="2d" id="settle-canvas" style="width:360px;height:600px;position:fixed;left:-9999px;top:0;"></canvas>
