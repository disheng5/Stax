<view class="container">
  <view class="hero">
    <view class="logo">Stax</view>
    <view class="slogan">Hold'em, held right.</view>
    <view class="zh-name">长河筹略</view>
    <view class="quote">
      <view class="quote-text">「{{quote.text}}」</view>
      <view class="quote-from">— {{quote.from}}</view>
    </view>
  </view>

  <view class="actions">
    <view class="action-btn action-btn--primary" bindtap="onCreate">开局</view>
    <view class="action-btn action-btn--ghost" bindtap="onJoin">加入</view>
    <view class="action-btn action-btn--ghost" bindtap="onHistory">战绩</view>
  </view>

  <view class="section-title">进行中的牌局</view>
  <block wx:if="{{ongoingGames.length}}">
    <view class="card" wx:for="{{ongoingGames}}" wx:key="_id" data-id="{{item._id}}" bindtap="onOpenGame">
      <view class="game-name">{{item.name}}</view>
      <view class="text-sub">{{item.players.length}} 人 · {{item.inviteCode}}</view>
    </view>
  </block>
  <empty-state wx:elif="{{!loading}}" title="还没有进行中的牌局" desc="点击上方按钮创建或加入" />

  <view class="share-cta">
    <button class="btn btn--ghost btn--block share-btn" open-type="share">分享 Stax</button>
    <view class="share-desc">记账 · 计时 · AA · AI 复盘 · 战绩分析</view>
  </view>
</view>
