<view class="container">
  <view class="card entry" bindtap="onTerms">
    <view class="title">术语词典</view>
    <view class="desc text-sub">50+ 中英术语，秒查秒懂</view>
  </view>
  <view class="card entry" bindtap="onChart">
    <view class="title">起手牌表</view>
    <view class="desc text-sub">169 种起手牌强度可视化</view>
  </view>
  <view class="card entry" bindtap="onRules">
    <view class="title">规则速览</view>
    <view class="desc text-sub">从盲注到 showdown 一文看懂</view>
  </view>
</view>
