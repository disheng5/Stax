<view class="container">
  <view wx:if="{{loading}}" class="loading-hint text-sub">加载中…</view>

  <block wx:if="{{!loading}}">
    <block wx:if="{{circles.length}}">
      <view class="section-title">我的积分榜</view>
      <view class="card circle-row" wx:for="{{circles}}" wx:key="_id" data-id="{{item._id}}" bindtap="onOpenCircle">
        <view class="circle-top">
          <view class="circle-name">{{item.name}}</view>
          <view class="circle-rank" wx:if="{{item.myRank}}">{{item.myRank}}</view>
        </view>
        <view class="circle-meta">{{item.seasonInfo}}</view>
      </view>
      <view class="join-row">
        <view class="join-btn" bindtap="onCreate">＋ 创建积分榜</view>
      </view>
    </block>

    <block wx:else>
      <view class="empty-card card">
        <view class="empty-title">还没有积分榜</view>
        <view class="empty-sub text-sub">创建后分享邀请，好友点击即可加入</view>
        <view class="empty-actions">
          <button class="btn btn--primary" bindtap="onCreate">创建积分榜</button>
        </view>
      </view>
    </block>
  </block>
</view>
