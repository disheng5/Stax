<view class="container" wx:if="{{game}}">
  <view class="timer-toggle" bindtap="onToggleTimer">
    <text>盲注计时</text>
    <text class="text-sub">{{showTimer ? '收起' : '需要时展开'}}</text>
  </view>

  <view wx:if="{{showTimer}}">
    <blind-timer
      currentLevel="{{game.currentLevel}}"
      blindStructure="{{game.blindStructure}}"
      blindUpMinutes="{{game.blindUpMinutes}}"
      levelStartedAt="{{game.levelStartedAt}}"
      paused="{{game.paused}}"
      pausedAt="{{game.pausedAt}}"
      pausedAccumMs="{{game.pausedAccumMs}}"
      isHost="{{isHost}}"
      bind:timeup="onTimeUp"
    />
    <view class="timer-actions" wx:if="{{isHost && !viewerMode && game.status === 'ongoing'}}">
      <button class="btn btn--ghost timer-btn" bindtap="onPause">{{game.paused ? '恢复计时' : '暂停计时'}}</button>
      <button class="btn btn--ghost timer-btn" bindtap="onLevelUp">升盲</button>
    </view>
  </view>

  <view class="game-top card">
    <view class="top-title">{{game.name || 'Stax 牌局'}}</view>
    <view class="room-config">盲注 {{game.smallBlind}}/{{game.bigBlind}} · 每手 {{game.buyIn}}</view>
    <view class="top-actions">
      <view class="invite-chip" bindtap="onCopyCode">邀请码 {{game.inviteCode}}</view>
      <button class="share-small" open-type="share">邀请</button>
    </view>
  </view>

  <view class="notice" wx:if="{{game.players.length <= 1}}">当前只有 1 位玩家，请分享给好友邀请加入</view>

  <view class="viewer-note card" wx:if="{{viewerMode && !isPlayer}}">
    <view class="viewer-title">朋友邀你加入</view>
    <view class="text-sub">点击下方按钮直接上桌，或继续围观。</view>
    <view class="viewer-actions">
      <button class="btn btn--primary" bindtap="onJoinAsPlayer" disabled="{{joining}}">上桌</button>
      <button class="btn btn--ghost" bindtap="onCopyCode">复制邀请码</button>
    </view>
  </view>

  <view class="section-head">
    <view class="section-title">积分情况</view>
    <view class="text-sub">{{game.checkedOutCount || 0}}/{{game.players.length}} 已下桌</view>
  </view>
  <view class="table-head">
    <text>玩家</text>
    <text>手数</text>
    <text>码量</text>
    <text>盈亏</text>
  </view>
  <view class="players">
      <player-card
        wx:for="{{game.players}}" wx:key="openid"
        player="{{item}}" isHost="{{isHost && !viewerMode}}" gameStatus="{{game.status}}"
        isSelf="{{item.openid === myOpenid && !viewerMode}}"
        canSelfOperate="{{game.playerOpsShared !== false}}"
        bind:rebuy="onRebuy" bind:addon="onAddOn" bind:eliminate="onEliminate"
        bind:selfrebuy="onSelfRebuy" bind:settleself="onSettleSelf"
      />
  </view>

  <view class="section-title" wx:if="{{recentTx.length}}">最近流水</view>
  <view class="card tx-list" wx:if="{{recentTx.length}}">
    <view class="tx {{tx.revoked ? 'revoked' : ''}}" wx:for="{{recentTx}}" wx:for-item="tx" wx:key="_id">
      <view class="tx-main">
        <text class="tx-type">{{txTypeLabel[tx.type]}}</text>
        <text class="tx-name">{{tx.nickname}}</text>
        <text class="tx-amount" wx:if="{{tx.amount}}">{{tx.amount}}</text>
        <text class="tx-by text-sub" wx:if="{{!tx.byHost && (tx.type === 'rebuy' || tx.type === 'addOn')}}"> 自助</text>
      </view>
      <button wx:if="{{isHost && !tx.revoked && (tx.type === 'rebuy' || tx.type === 'addOn')}}"
              class="btn btn--ghost btn-tiny" data-id="{{tx._id}}" bindtap="onRevokeTx">撤销</button>
      <text class="text-sub" wx:elif="{{tx.revoked}}">已撤销</text>
    </view>
  </view>

  <view class="host-panel" wx:if="{{isPlayer && !viewerMode && game.status === 'ongoing'}}">
    <view class="settle-entry card" wx:if="{{isHost || game.playerOpsShared === false}}">
      <view>
        <view class="settle-title">最终结算</view>
        <view class="text-sub">房主处理费用、确认账平并生成结果</view>
      </view>
      <button class="btn btn--danger settle-btn" bindtap="onEndGame">结算</button>
    </view>
  </view>
</view>

<empty-state wx:elif="{{!loading}}" title="牌局不存在或已结束" />
