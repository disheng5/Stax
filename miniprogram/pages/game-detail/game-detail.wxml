<view class="container" wx:if="{{game}}">
  <view class="game-info">
    <text class="info-text">{{game.name || 'StaxKit 记录'}}</text>
    <view class="info-actions">
      <view class="share-btn" bindtap="onShare">{{game.status === 'ongoing' ? '邀请' : '分享'}}</view>
      <view class="share-btn" wx:if="{{isPlayer && !viewerMode}}" bindtap="onOpenExpense">费用分摊</view>
    </view>
  </view>
  <view class="game-sub-info">
    <text class="text-sub">娱乐积分 · 盲注 {{game.smallBlind}}/{{game.bigBlind}} · 每份 {{game.buyIn}}<text wx:if="{{game.scoreRatio > 1}}"> · {{game.scoreRatio}}:1</text></text>
  </view>

  <view class="notice" wx:if="{{game.players.length <= 1 && game.status === 'ongoing'}}">当前只有 1 位玩家，请分享给好友邀请加入</view>

  <view class="viewer-note card" wx:if="{{viewerMode && !isPlayer && game.status === 'ongoing'}}">
    <view class="viewer-title">朋友邀你加入</view>
    <view class="text-sub">点击下方按钮直接上桌</view>
    <button class="btn btn--primary" bindtap="onJoinAsPlayer" disabled="{{joining}}" style="margin-top:16rpx;">上桌</button>
  </view>

  <view class="settle-summary" wx:if="{{game.status === 'ended' && settleResult}}">
    <view class="summary-item">
      <text class="summary-label">本局时长</text>
      <text class="summary-value">{{settleResult.duration}}</text>
    </view>
    <view class="summary-sep"></view>
    <view class="summary-item">
      <text class="summary-label">参与玩家</text>
      <text class="summary-value">{{settleResult.profitList.length}} 人</text>
    </view>
  </view>

  <view class="section-head" wx:if="{{isPlayer && !viewerMode && game.status === 'ongoing'}}">
    <view class="section-title">积分情况</view>
    <view class="quick-actions">
      <view class="quick-btn primary" bindtap="onQuickBuy">买入</view>
      <view class="quick-btn ghost" bindtap="onQuickSettle">结算</view>
    </view>
  </view>
  <view class="section-head" wx:elif="{{game.status === 'ongoing'}}">
    <view class="section-title">积分情况</view>
  </view>

  <view class="table-head">
    <text>成员</text>
    <text>手数</text>
    <text>剩余积分</text>
    <text>盈亏</text>
  </view>
  <view class="players">
      <player-card
        wx:for="{{game.players}}" wx:key="openid"
        player="{{item}}" isHost="{{isHost && !viewerMode}}" gameStatus="{{game.status}}"
        isSelf="{{item.openid === myOpenid && !viewerMode}}"
        canSelfOperate="{{game.playerOpsShared !== false}}"
        isWinner="{{item.openid === settleWinnerOpenid}}"
        bind:playertap="onPlayerTap"
      />
  </view>

  <view class="settle-bar" wx:if="{{game.status === 'ongoing'}}">
    <text class="bar-item" wx:if="{{!allCheckedOut}}">未结算: {{game.players.length - (game.checkedOutCount || 0)}}</text>
    <text class="bar-item text-gain" wx:elif="{{settleDiff === 0}}">✓ 账平</text>
    <text class="bar-item text-danger" wx:else>ⓘ 账不平</text>
    <text class="bar-item text-gain">水上: {{aboveTotal > 0 ? '+' : ''}}{{aboveTotal}}</text>
    <text class="bar-item text-loss">水下: {{belowTotal}}</text>
  </view>

  <view class="settle-bar ended" wx:if="{{game.status === 'ended' && settleResult}}">
    <text class="bar-item text-gain" wx:if="{{settleResult.aboveTotal + settleResult.belowTotal === 0}}">✓ 账平</text>
    <text class="bar-item text-warning" wx:else>ⓘ 账不平</text>
    <text class="bar-item text-gain">水上: +{{settleResult.aboveTotal}}</text>
    <text class="bar-item text-loss">水下: {{settleResult.belowTotal}}</text>
    <text class="bar-item text-warning" wx:if="{{settleResult.aboveTotal + settleResult.belowTotal !== 0}}">账差: {{settleResult.aboveTotal + settleResult.belowTotal > 0 ? '+' : ''}}{{settleResult.aboveTotal + settleResult.belowTotal}}</text>
  </view>

  <view class="section-title ledger-title" wx:if="{{recentTx.length || (settleResult && settleResult.expenseRows.length)}}">流水记录</view>
  <view class="card tx-list" wx:if="{{recentTx.length || (settleResult && settleResult.expenseRows.length)}}">
    <view class="expense-block" wx:if="{{settleResult && settleResult.expenseRows.length}}">
      <view class="expense-head">
        <text class="expense-title">费用分摊</text>
        <text class="expense-summary">共 {{settleResult.extraCost}} · {{settleResult.expenseModeLabel}} · 不计积分</text>
      </view>
      <view class="expense-row" wx:for="{{settleResult.expenseRows}}" wx:key="openid">
        <text class="expense-name">{{item.nickname}}</text>
        <text class="expense-share">-{{item.share}}</text>
      </view>
      <view class="expense-divider" wx:if="{{recentTx.length}}"></view>
    </view>
    <view class="tx {{tx.revoked ? 'revoked' : ''}}" wx:for="{{recentTx}}" wx:for-item="tx" wx:key="_id">
      <text class="tx-time">{{tx.timeStr}}</text>
      <text class="tx-type tx-type--{{tx.typeClass}}">{{tx.typeLabel}}</text>
      <text class="tx-name">{{tx.nickname}}</text>
      <text class="tx-detail">
        <text
          wx:for="{{tx.detailParts}}"
          wx:for-item="part"
          wx:key="key"
          class="{{part.emphasis ? 'tx-detail-number' : ''}}"
        >{{part.text}}</text>
      </text>
      <text class="tx-revoked" wx:if="{{tx.revoked}}">已撤销</text>
    </view>
  </view>

</view>

<view wx:elif="{{loading}}" class="container">
  <view class="sk sk-line sk-w-60" style="height: 40rpx; margin: 8rpx 0 32rpx;"></view>
  <view class="sk-card sk-row" wx:for="{{[1, 2, 3, 4]}}" wx:key="*this">
    <view class="sk sk-avatar"></view>
    <view class="sk-flex">
      <view class="sk sk-line sk-w-40"></view>
      <view class="sk sk-line sk-w-80"></view>
    </view>
  </view>
</view>
<view wx:elif="{{loadError}}" class="container">
  <view class="card" style="text-align: center; padding: 64rpx 32rpx;">
    <view style="margin-bottom: 32rpx;">加载失败，请检查网络后重试</view>
    <button class="btn btn--primary" bindtap="onRetryLoad">重新加载</button>
  </view>
</view>
<empty-state wx:else title="房间不存在或已结束" />

<view class="hands-mask" wx:if="{{handsPicker.show}}" bindtap="onHandsClose">
  <view class="hands-sheet" catchtap="onHandsStop">
    <view class="hands-title">{{handsPicker.title}} 几手</view>
    <view class="hands-row">
      <view class="hands-step minus {{handsPicker.hands <= 1 ? 'disabled' : ''}}" bindtap="onHandsMinus">-</view>
      <input class="hands-input" type="number" value="{{handsPicker.hands}}" bindinput="onHandsInput" confirm-type="done" />
      <view class="hands-step plus {{handsPicker.hands >= 99 ? 'disabled' : ''}}" bindtap="onHandsPlus">+</view>
    </view>
    <view class="hands-hint text-sub">每手 {{game.buyIn}} · 共 {{handsPicker.hands * game.buyIn}}</view>
    <view class="hands-actions">
      <view class="hands-btn cancel" bindtap="onHandsClose">取消</view>
      <view class="hands-btn confirm" bindtap="onHandsConfirm">确定</view>
    </view>
  </view>
</view>

<view class="hands-mask expense-mask" wx:if="{{expensePanel.show}}" bindtap="onExpensePanelClose">
  <view class="expense-sheet" catchtap="onExpensePanelStop">
    <view class="expense-modal-head">
      <view class="expense-close" bindtap="onExpensePanelClose">×</view>
      <view class="expense-modal-title">费用分摊</view>
      <view class="expense-head-spacer"></view>
    </view>

    <view class="expense-form">
      <view class="expense-field">
        <text class="expense-field-label">费用总额</text>
        <input
          class="expense-amount-input"
          type="digit"
          placeholder="0"
          value="{{expensePanel.extraCost}}"
          bindinput="onExtraCostInput"
        />
      </view>
      <picker
        mode="selector"
        range="{{['全员平均', '水上比例', '水上平均', 'MVP买单']}}"
        value="{{expensePanel.expenseMode === 'all' ? 0 : expensePanel.expenseMode === 'winner' ? 1 : expensePanel.expenseMode === 'winnerEven' ? 2 : 3}}"
        bindchange="onExpenseModePick"
      >
        <view class="expense-field">
          <text class="expense-field-label">分摊方式</text>
          <view class="expense-mode-value">{{expenseModeLabels[expensePanel.expenseMode]}}<text class="expense-mode-arrow">▾</text></view>
        </view>
      </picker>
      <view class="expense-compliance-note">仅记录费用分摊，不计入本局积分结果</view>
    </view>

    <view class="expense-actions">
      <view class="expense-button expense-button--cancel" bindtap="onExpensePanelClose">取消</view>
      <view class="expense-button expense-button--confirm {{expensePanel.submitting ? 'expense-button--disabled' : ''}}" bindtap="onExpenseConfirm">
        {{expensePanel.submitting ? '保存中…' : '确定'}}
      </view>
    </view>
  </view>
</view>
