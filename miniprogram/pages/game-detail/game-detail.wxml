<view class="container" wx:if="{{game}}">
  <view class="game-info">
    <text class="info-text">{{game.name || 'StaxKit 牌局'}}</text>
    <view class="share-btn" bindtap="onShare">{{game.status === 'ongoing' ? '邀请' : '分享'}}</view>
  </view>
  <view class="game-sub-info">
    <text class="text-sub">盲注 {{game.smallBlind}}/{{game.bigBlind}} · 每手 {{game.buyIn}}<text wx:if="{{game.scoreRatio > 1}}"> · {{game.scoreRatio}}:1</text></text>
  </view>

  <view class="notice" wx:if="{{game.players.length <= 1 && game.status === 'ongoing'}}">当前只有 1 位玩家，请分享给好友邀请加入</view>

  <view class="viewer-note card" wx:if="{{viewerMode && !isPlayer && game.status === 'ongoing'}}">
    <view class="viewer-title">朋友邀你加入</view>
    <view class="text-sub">点击下方按钮直接上桌</view>
    <button class="btn btn--primary" bindtap="onJoinAsPlayer" disabled="{{joining}}" style="margin-top:16rpx;">上桌</button>
  </view>

  <view class="section-head" wx:if="{{isPlayer && !viewerMode && game.status === 'ongoing'}}">
    <view class="section-title">积分情况</view>
    <view class="quick-actions">
      <view class="quick-btn primary" bindtap="onQuickBuy">买入</view>
      <view class="quick-btn ghost" bindtap="onQuickSettle">结算</view>
    </view>
  </view>
  <view class="section-head" wx:elif="{{game.status === 'ongoing'}}">
    <view class="section-title">积分情况</view>
  </view>

  <view wx:if="{{game.status === 'ongoing'}}">
    <view class="table-head">
      <text>玩家</text>
      <text>手数</text>
      <text>码量</text>
      <text>盈亏</text>
    </view>
    <view class="players">
        <player-card
          wx:for="{{game.players}}" wx:key="openid"
          player="{{item}}" isHost="{{isHost && !viewerMode}}" gameStatus="{{game.status}}"
          isSelf="{{item.openid === myOpenid && !viewerMode}}"
          canSelfOperate="{{game.playerOpsShared !== false}}"
          bind:playertap="onPlayerTap"
        />
    </view>
  </view>

  <view class="settle-bar" wx:if="{{game.status === 'ongoing' && game.checkedOutCount > 0}}">
    <text>未结算: {{game.players.length - (game.checkedOutCount || 0)}}</text>
    <text wx:if="{{allCheckedOut}}" class="{{settleDiff === 0 ? 'text-success' : 'text-danger'}}">
      {{settleDiff === 0 ? '水平' : '差额 ' + settleDiff}}
    </text>
  </view>

  <view class="host-panel" wx:if="{{isHost && !viewerMode && game.status === 'ongoing' && allCheckedOut && settleDiff === 0}}">
    <view class="quick-btn primary end-btn" bindtap="onEndGame">结束对局</view>
  </view>

  <view class="settle-result" wx:if="{{game.status === 'ended' && settleResult}}">
    <view class="result-header">
      <view class="result-game-name">{{settleResult.gameName}}</view>
      <view class="result-date text-sub">{{settleResult.dateStr}}</view>
    </view>

    <view class="result-summary">
      <view class="summary-block">
        <view class="summary-label">本局时长</view>
        <view class="summary-value">{{settleResult.duration}}</view>
        <view class="summary-sub text-sub">{{settleResult.profitList.length}} 人参与</view>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-block">
        <view class="summary-label">赢面玩家</view>
        <view class="summary-value">{{settleResult.winnerCount}}</view>
        <view class="summary-sub text-sub">共 {{settleResult.profitList.length}} 人</view>
      </view>
    </view>

    <view class="result-rows">
      <view class="result-row {{item.profit > 0 ? 'win' : item.profit < 0 ? 'lose' : ''}}" wx:for="{{settleResult.profitList}}" wx:key="openid">
        <view class="result-cell-name">
          <view class="result-avatar-wrap">
            <image class="result-avatar" src="{{item.avatar || '/images/default-avatar.png'}}" />
            <view class="crown" wx:if="{{item.openid === settleResult.winner.openid}}"></view>
          </view>
          <text>{{item.nickname}}</text>
        </view>
        <text class="result-cell-sub">{{item.buyInCount}}手 · {{item.finalStack}}</text>
        <text class="result-profit {{item.profit > 0 ? 'text-gold' : item.profit < 0 ? 'text-danger' : 'text-sub'}}">{{item.profit > 0 ? '+' : ''}}{{item.profit}}</text>
      </view>
    </view>

    <view class="result-aa" wx:if="{{settleResult.extraCost > 0}}">
      <text class="text-sub">其他费用 {{settleResult.extraCost}} · {{settleResult.expenseMode === 'winner' ? '水上AA' : '全员AA'}}</text>
    </view>

    <view class="result-waterline">
      <view class="waterline-item">
        <text class="waterline-num text-gold">{{settleResult.aboveCount}}</text>
        <text class="waterline-label">水上</text>
      </view>
      <view class="waterline-divider"></view>
      <view class="waterline-item">
        <text class="waterline-num" style="color:rgba(255,255,255,0.6)">{{settleResult.evenCount}}</text>
        <text class="waterline-label">水平</text>
      </view>
      <view class="waterline-divider"></view>
      <view class="waterline-item">
        <text class="waterline-num text-danger">{{settleResult.belowCount}}</text>
        <text class="waterline-label">水下</text>
      </view>
    </view>
  </view>

  <view class="section-title" wx:if="{{recentTx.length}}">流水记录</view>
  <view class="card tx-list" wx:if="{{recentTx.length}}">
    <view class="tx {{tx.revoked ? 'revoked' : ''}}" wx:for="{{recentTx}}" wx:for-item="tx" wx:key="_id">
      <view class="tx-main">
        <view class="tx-line">
          <text class="tx-type">{{txTypeLabel[tx.type]}}</text>
          <text class="tx-name">{{tx.nickname}}</text>
          <text class="tx-time text-sub">{{tx.timeStr}}</text>
        </view>
        <view class="tx-sub text-sub" wx:if="{{tx.type === 'buyIn' || tx.type === 'rebuy' || tx.type === 'addOn'}}">
          {{tx.hands}} 手 · 共 {{tx.accHands}} 手 · 总码量 {{tx.accAmount}}
        </view>
        <view class="tx-sub text-sub" wx:elif="{{tx.type === 'settlePartial' || tx.type === 'settle'}}">
          结算筹码 {{tx.amount}}
        </view>
      </view>
      <text class="text-sub" wx:if="{{tx.revoked}}">已撤销</text>
    </view>
  </view>

  <view class="card exclude-card" wx:if="{{isHost && game.status === 'ended'}}">
    <view class="text-sub">{{game.excludeFromSeason ? '本局已排除赛季积分计算' : '本局计入赛季积分'}}</view>
    <view class="exclude-btn" bindtap="onToggleExclude">{{game.excludeFromSeason ? '恢复计入' : '排除本局'}}</view>
  </view>
</view>

<empty-state wx:elif="{{!loading}}" title="牌局不存在或已结束" />
<view wx:elif="{{loading}}" class="loading-hint text-sub">加载中…</view>

<view class="hands-mask" wx:if="{{handsPicker.show}}" bindtap="onHandsClose">
  <view class="hands-sheet" catchtap="onHandsStop">
    <view class="hands-title">{{handsPicker.title}} 几手</view>
    <view class="hands-row">
      <view class="hands-step minus {{handsPicker.hands <= 1 ? 'disabled' : ''}}" bindtap="onHandsMinus">-</view>
      <input class="hands-input" type="number" value="{{handsPicker.hands}}" bindinput="onHandsInput" confirm-type="done" />
      <view class="hands-step plus {{handsPicker.hands >= 99 ? 'disabled' : ''}}" bindtap="onHandsPlus">+</view>
    </view>
    <view class="hands-hint text-sub">每手 {{game.buyIn}} · 共 {{handsPicker.hands * game.buyIn}}</view>
    <view class="hands-actions">
      <view class="hands-btn cancel" bindtap="onHandsClose">取消</view>
      <view class="hands-btn confirm" bindtap="onHandsConfirm">确定</view>
    </view>
  </view>
</view>

<view class="hands-mask" wx:if="{{finalPanel.show}}" bindtap="onFinalPanelClose">
  <view class="hands-sheet" catchtap="onFinalPanelStop">
    <view class="hands-title">结束对局</view>
    <view class="final-section">
      <view class="final-label text-sub">其他费用（可选）</view>
      <view class="final-row">
        <text class="text-sub">总额</text>
        <input class="final-input" type="digit" placeholder="0" value="{{finalPanel.extraCost || ''}}" bindinput="onExtraCostInput" />
      </view>
      <view class="presets" wx:if="{{finalPanel.extraCost > 0}}">
        <view class="preset {{finalPanel.expenseMode === 'all' ? 'active' : ''}}" data-k="all" bindtap="onExpenseModeChange">全员AA</view>
        <view class="preset {{finalPanel.expenseMode === 'winner' ? 'active' : ''}}" data-k="winner" bindtap="onExpenseModeChange">水上按比例</view>
      </view>
      <view class="final-hint text-sub">费用仅用于分摊记录，不影响盈亏积分</view>
    </view>
    <view class="hands-actions">
      <view class="hands-btn cancel" bindtap="onFinalPanelClose">取消</view>
      <view class="hands-btn confirm" bindtap="onFinalConfirm">确认结束</view>
    </view>
  </view>
</view>
