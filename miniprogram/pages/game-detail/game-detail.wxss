
.game-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 4rpx;
  margin-bottom: 12rpx;
}

.info-text {
  color: var(--text-sub);
  font-size: 24rpx;
}

.share-btn {
  flex-shrink: 0;
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-sm);
  background: var(--table-green);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 52rpx;
}

.notice {
  margin-bottom: 20rpx;
  padding: 18rpx 24rpx;
  border-radius: var(--radius-sm);
  border: 2rpx solid rgba(201, 169, 97, 0.28);
  background: rgba(201, 169, 97, 0.12);
  color: #8a6418;
  font-size: 24rpx;
  line-height: 1.5;
}

.viewer-note {
  padding: 26rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(43, 108, 176, 0.12);
  box-shadow: none;
}

.viewer-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.viewer-actions .btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 26rpx;
}

.viewer-title {
  margin-bottom: 4rpx;
  color: var(--table-green);
  font-size: 28rpx;
  font-weight: 600;
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 24rpx 4rpx 14rpx;
}

.section-title {
  color: var(--text);
  font-size: 28rpx;
  font-weight: 700;
}

.table-head {
  display: grid;
  grid-template-columns: 1fr 80rpx 120rpx 120rpx;
  gap: 8rpx;
  padding: 0 24rpx 12rpx;
  color: var(--text-sub);
  font-size: 22rpx;
}

.table-head text:not(:first-child) {
  text-align: right;
}

.players {
  margin-bottom: 28rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-md);
  background: var(--card);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.host-panel {
  margin-top: 6rpx;
}

.settle-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx 28rpx;
}

.settle-title {
  margin-bottom: 4rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.settle-btn {
  flex-shrink: 0;
  width: 156rpx;
  height: 76rpx;
  font-size: 26rpx;
  line-height: 76rpx;
}

.tx-list {
  padding: 12rpx 24rpx;
}

.tx {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.tx:last-child {
  border: none;
}

.tx.revoked {
  opacity: 0.5;
  text-decoration: line-through;
}

.tx-main {
  flex: 1;
  min-width: 0;
}

.tx-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  flex-wrap: wrap;
}

.tx-type {
  color: var(--text-sub);
}

.tx-name {
  font-weight: 500;
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tx-by {
  font-size: 22rpx;
}

.tx-time {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--text-sub);
  flex-shrink: 0;
}

.tx-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

.btn-tiny {
  flex-shrink: 0;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 16rpx;
  font-size: 22rpx;
}

.hands-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.hands-sheet {
  width: 580rpx;
  padding: 40rpx 40rpx 30rpx;
  border-radius: var(--radius-lg);
  background: #fff;
  box-sizing: border-box;
}

.hands-title {
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.hands-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  margin: 32rpx 0 18rpx;
}

.hands-step {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(43, 108, 176, 0.1);
  color: var(--table-green);
  font-size: 44rpx;
  font-weight: 700;
  text-align: center;
  line-height: 88rpx;
}

.hands-step.disabled { opacity: 0.4; }
.hands-step:active { background: rgba(43, 108, 176, 0.22); }

.hands-input {
  width: 168rpx;
  height: 88rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--table-green);
}

.hands-hint {
  text-align: center;
  font-size: 24rpx;
}

.hands-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.hands-btn {
  flex: 1;
  height: 80rpx;
  border-radius: var(--radius-md);
  text-align: center;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.hands-btn.cancel { background: rgba(0,0,0,0.05); color: var(--text-sub); }
.hands-btn.confirm { background: var(--table-green); color: #fff; }

.exclude-card { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 28rpx; margin-top: 16rpx; }
.exclude-btn { font-size: 24rpx; color: var(--table-green); }

.quick-actions {
  display: flex;
  gap: 16rpx;
}

.quick-btn {
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 52rpx;
}

.quick-btn.primary {
  background: var(--table-green);
  color: #fff;
}

.quick-btn.ghost {
  background: rgba(0,0,0,0.05);
  color: var(--text);
}

.settle-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-sub);
}

.host-panel {
  margin-top: 24rpx;
}

.end-btn {
  text-align: center;
  width: 100%;
}

.game-sub-info {
  margin-bottom: 16rpx;
}

.settle-result {
  margin: 24rpx 0;
  background: linear-gradient(135deg, #1A1B2E 0%, #0F3460 100%);
  border-radius: var(--radius-md);
  padding: 32rpx 28rpx;
  color: #fff;
}

.result-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #C9A961;
  margin-bottom: 24rpx;
  letter-spacing: 4rpx;
}

.result-rows {
  margin-bottom: 24rpx;
}

.result-row {
  display: grid;
  grid-template-columns: 1fr 160rpx 120rpx;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.result-row:last-child { border-bottom: none; }

.result-row.win { background: rgba(201,169,97,0.08); border-radius: 8rpx; padding: 16rpx 8rpx; }
.result-row.lose { background: rgba(200,16,46,0.06); border-radius: 8rpx; padding: 16rpx 8rpx; }

.result-cell-name {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.result-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
}

.result-cell-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  text-align: right;
}

.result-profit {
  font-size: 28rpx;
  font-weight: 700;
  text-align: right;
}

.result-subtitle {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  margin-bottom: 12rpx;
  margin-top: 8rpx;
}

.transfer-row {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 8rpx;
}

.arrow { color: rgba(255,255,255,0.4); }

.text-gold { color: #C9A961; font-weight: 700; }

.result-aa {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.08);
}

.result-actions {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}

.result-share {
  background: rgba(255,255,255,0.12);
  color: #fff;
  font-size: 24rpx;
  padding: 0 40rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: var(--radius-sm);
  font-weight: 600;
}

.final-section {
  padding: 16rpx 0 8rpx;
}

.final-label {
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.final-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.final-input {
  width: 240rpx;
  height: 72rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  text-align: right;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: var(--text);
}

.final-hint {
  font-size: 22rpx;
  margin-top: 8rpx;
}
