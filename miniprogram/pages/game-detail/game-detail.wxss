
.game-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 4rpx;
  margin-bottom: 12rpx;
}

.info-text {
  color: var(--text-sub);
  font-size: 24rpx;
}

.share-btn {
  flex-shrink: 0;
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-sm);
  background: var(--table-green);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 52rpx;
}

.notice {
  margin-bottom: 20rpx;
  padding: 18rpx 24rpx;
  border-radius: var(--radius-sm);
  border: 2rpx solid rgba(201, 169, 97, 0.28);
  background: rgba(201, 169, 97, 0.12);
  color: #8a6418;
  font-size: 24rpx;
  line-height: 1.5;
}

.viewer-note {
  padding: 26rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(43, 108, 176, 0.12);
  box-shadow: none;
}

.viewer-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.viewer-actions .btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 26rpx;
}

.viewer-title {
  margin-bottom: 4rpx;
  color: var(--table-green);
  font-size: 28rpx;
  font-weight: 600;
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 24rpx 4rpx 14rpx;
}

.section-title {
  color: var(--text);
  font-size: 28rpx;
  font-weight: 700;
}

.table-head {
  display: grid;
  grid-template-columns: 1fr 80rpx 120rpx 120rpx;
  gap: 8rpx;
  padding: 0 24rpx 12rpx;
  color: var(--text-sub);
  font-size: 22rpx;
}

.table-head text:not(:first-child) {
  text-align: right;
}

.players {
  margin-bottom: 28rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-md);
  background: var(--card);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.host-panel {
  margin-top: 6rpx;
}

.settle-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx 28rpx;
}

.settle-title {
  margin-bottom: 4rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.settle-btn {
  flex-shrink: 0;
  width: 156rpx;
  height: 76rpx;
  font-size: 26rpx;
  line-height: 76rpx;
}

.tx-list {
  padding: 10rpx 24rpx;
}

.tx {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 40rpx;
  padding: 10rpx 0;
  border-bottom: 2rpx solid var(--border);
  font-size: 24rpx;
  line-height: 40rpx;
  white-space: nowrap;
}

.tx:last-child {
  border: none;
}

.tx.revoked {
  opacity: 0.5;
  text-decoration: line-through;
}

.tx-type {
  color: var(--text-sub);
  flex-shrink: 0;
}

.tx-type--entry { color: var(--table-green); }
.tx-type--buy { color: #d48806; }
.tx-type--remove { color: var(--loss); }
.tx-type--settle { color: var(--text-sub); }

.tx-time {
  width: 72rpx;
  color: var(--text-sub);
  font-size: 22rpx;
  flex-shrink: 0;
}

.tx-name {
  max-width: 180rpx;
  min-width: 0;
  overflow: hidden;
  color: var(--text);
  font-weight: 600;
  text-overflow: ellipsis;
}

.tx-detail {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: var(--text-sub);
  font-size: 22rpx;
  text-overflow: ellipsis;
}

.tx-revoked {
  flex-shrink: 0;
  color: var(--text-sub);
  font-size: 22rpx;
}

.expense-block {
  padding: 4rpx 0 2rpx;
}

.expense-head,
.expense-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.expense-head {
  min-height: 48rpx;
  margin-bottom: 4rpx;
}

.expense-title {
  flex-shrink: 0;
  font-size: 27rpx;
  font-weight: 700;
}

.expense-summary {
  overflow: hidden;
  color: var(--text-sub);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.expense-row {
  min-height: 48rpx;
  font-size: 24rpx;
  line-height: 48rpx;
}

.expense-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.expense-share {
  flex-shrink: 0;
  color: #b78b2f;
  font-weight: 600;
}

.expense-divider {
  height: 2rpx;
  margin-top: 8rpx;
  background: var(--border);
}

.btn-tiny {
  flex-shrink: 0;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 16rpx;
  font-size: 22rpx;
}

.hands-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.hands-sheet {
  width: 580rpx;
  padding: 40rpx 40rpx 30rpx;
  border-radius: var(--radius-lg);
  background: #fff;
  box-sizing: border-box;
}

.hands-title {
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.hands-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  margin: 32rpx 0 18rpx;
}

.hands-step {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(43, 108, 176, 0.1);
  color: var(--table-green);
  font-size: 44rpx;
  font-weight: 700;
  text-align: center;
  line-height: 88rpx;
}

.hands-step.disabled { opacity: 0.4; }
.hands-step:active { background: rgba(43, 108, 176, 0.22); }

.hands-input {
  width: 168rpx;
  height: 88rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--table-green);
}

.hands-hint {
  text-align: center;
  font-size: 24rpx;
}

.hands-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.hands-btn {
  flex: 1;
  height: 80rpx;
  border-radius: var(--radius-md);
  text-align: center;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.hands-btn.cancel { background: rgba(0,0,0,0.05); color: var(--text-sub); }
.hands-btn.confirm { background: var(--table-green); color: #fff; }

.exclude-btn { font-size: 24rpx; color: var(--table-green); }

.quick-actions {
  display: flex;
  gap: 16rpx;
}

.quick-btn {
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 52rpx;
}

.quick-btn.primary {
  background: var(--table-green);
  color: #fff;
}

.quick-btn.ghost {
  background: rgba(0,0,0,0.05);
  color: var(--text);
}

.settle-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 16rpx 24rpx;
  margin-top: 0;
  font-size: 24rpx;
  background: rgba(0,0,0,0.03);
  border-top: 1rpx solid var(--border);
}

.settle-bar.ended {
  background: rgba(43,108,176,0.04);
  border-top: 1rpx solid rgba(43,108,176,0.1);
}

.bar-item {
  flex-shrink: 0;
}

.text-warning {
  color: #fa8c16;
}

.settle-summary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin: 20rpx 0;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(43, 108, 176, 0.08);
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.summary-label {
  font-size: 20rpx;
  color: var(--text-sub);
  margin-bottom: 6rpx;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}

.summary-sep {
  width: 1rpx;
  height: 48rpx;
  background: rgba(0,0,0,0.08);
}

.check-text {
  color: var(--success);
  font-weight: 600;
}

.host-panel {
  margin-top: 24rpx;
}

.end-btn {
  text-align: center;
  width: 100%;
}

.game-sub-info {
  margin-bottom: 16rpx;
}

.final-section {
  padding: 16rpx 0 8rpx;
}

.final-label {
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.final-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.final-input {
  width: 240rpx;
  height: 72rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  text-align: right;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: var(--text);
}

.final-hint {
  font-size: 22rpx;
  margin-top: 8rpx;
}

/* 顶栏双操作按钮 */
.info-actions { display: flex; gap: 16rpx; flex-shrink: 0; }

/* 结束后可编辑提示 */
.edit-window-hint { text-align: center; margin: 12rpx 0 4rpx; font-size: 22rpx; }

/* 费用分摊面板 */
.final-picker { flex: 1; text-align: right; }
.picker-value { color: var(--text); font-size: 30rpx; }
