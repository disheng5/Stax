.timer-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 16rpx 22rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.7);
  color: var(--text-sub);
  font-size: 24rpx;
}

.timer-actions {
  display: flex;
  gap: 12rpx;
  margin: -2rpx 0 20rpx;
}

.timer-btn {
  flex: 1;
  height: 64rpx;
  font-size: 24rpx;
  line-height: 64rpx;
}

.game-top {
  padding: 26rpx 28rpx;
  margin-bottom: 18rpx;
  box-shadow: none;
}

.top-title {
  color: var(--text);
  font-size: 34rpx;
  font-weight: 700;
}

.room-config {
  margin-top: 10rpx;
  color: var(--text-sub);
  font-size: 25rpx;
}

.top-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 22rpx;
}

.invite-chip {
  flex: 1;
  height: 68rpx;
  padding: 0 20rpx;
  border-radius: var(--radius-sm);
  background: rgba(11, 110, 79, 0.08);
  color: var(--table-green);
  font-family: 'Courier New', monospace;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 68rpx;
}

.share-small {
  flex-shrink: 0;
  width: 132rpx;
  height: 68rpx;
  padding: 0;
  border: none;
  border-radius: var(--radius-sm);
  background: var(--table-green);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 68rpx;
}

.share-small::after {
  border: none;
}

.notice {
  margin-bottom: 18rpx;
  padding: 18rpx 24rpx;
  border: 2rpx solid rgba(201, 169, 97, 0.28);
  background: rgba(201, 169, 97, 0.12);
  color: #8a6418;
  font-size: 24rpx;
}

.viewer-note {
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(11, 110, 79, 0.12);
  box-shadow: none;
}

.viewer-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.viewer-actions .btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 26rpx;
}

.viewer-title {
  margin-bottom: 4rpx;
  color: var(--table-green);
  font-size: 28rpx;
  font-weight: 600;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 28rpx 4rpx 14rpx;
}

.section-title {
  color: var(--text);
  font-size: 30rpx;
  font-weight: 700;
}

.table-head {
  display: grid;
  grid-template-columns: 1fr 88rpx 132rpx 118rpx;
  gap: 10rpx;
  padding: 0 0 14rpx;
  color: var(--text-sub);
  font-size: 23rpx;
}

.table-head text:not(:first-child) {
  text-align: right;
}

.players {
  overflow: hidden;
  margin-bottom: 28rpx;
  padding: 0 22rpx;
  border-radius: var(--radius-md);
  background: var(--card);
  box-shadow: var(--shadow-card);
}

.host-panel {
  margin-top: 6rpx;
}

.settle-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
}

.settle-title {
  margin-bottom: 4rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.settle-btn {
  flex-shrink: 0;
  width: 148rpx;
  height: 72rpx;
  font-size: 26rpx;
  line-height: 72rpx;
}

.tx-list {
  padding: 12rpx 24rpx;
}

.tx {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.tx:last-child {
  border: none;
}

.tx.revoked {
  opacity: 0.5;
  text-decoration: line-through;
}

.tx-main {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
}

.tx-type {
  color: var(--text-sub);
  margin-right: 8rpx;
}

.tx-name {
  margin-right: 8rpx;
  font-weight: 500;
}

.tx-amount {
  color: var(--gold);
  font-weight: 600;
}

.btn-tiny {
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 16rpx;
  font-size: 22rpx;
}
