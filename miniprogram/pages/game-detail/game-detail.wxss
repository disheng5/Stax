
.game-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 4rpx;
  margin-bottom: 10rpx;
}

.info-text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: var(--text-sub);
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.share-btn {
  flex-shrink: 0;
  height: 60rpx;
  padding: 0 22rpx;
  border-radius: var(--radius-sm);
  background: var(--table-green);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 60rpx;
}

.notice {
  margin-bottom: 20rpx;
  padding: 18rpx 24rpx;
  border-radius: var(--radius-sm);
  border: 2rpx solid rgba(201, 169, 97, 0.28);
  background: rgba(201, 169, 97, 0.12);
  color: #8a6418;
  font-size: 24rpx;
  line-height: 1.5;
}

.pending-note {
  margin-bottom: 20rpx;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-sm);
  background: rgba(43, 108, 176, 0.08);
  color: var(--text-sub);
  font-size: 22rpx;
  line-height: 1.5;
}

.viewer-note {
  padding: 26rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(43, 108, 176, 0.12);
  box-shadow: none;
}

.viewer-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.viewer-actions .btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 26rpx;
}

.viewer-title {
  margin-bottom: 4rpx;
  color: var(--table-green);
  font-size: 28rpx;
  font-weight: 600;
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 24rpx 4rpx 14rpx;
}

.section-title {
  color: var(--text);
  font-size: 28rpx;
  font-weight: 700;
}

.table-head {
  display: grid;
  grid-template-columns: 1fr 80rpx 120rpx 120rpx;
  gap: 8rpx;
  padding: 0 24rpx 12rpx;
  color: var(--text-sub);
  font-size: 22rpx;
}

.table-head text:not(:first-child) {
  text-align: right;
}

.players {
  margin-bottom: 28rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-md);
  background: var(--card);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.host-panel {
  margin-top: 6rpx;
}

.settle-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx 28rpx;
}

.settle-title {
  margin-bottom: 4rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.settle-btn {
  flex-shrink: 0;
  width: 156rpx;
  height: 76rpx;
  font-size: 26rpx;
  line-height: 76rpx;
}

.tx-list {
  background: #fff;
  padding: 0 24rpx;
  border-radius: 12rpx;
}

.tx {
  display: flex;
  align-items: flex-start;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #EEF1F4;
  font-size: 25rpx;
  line-height: 38rpx;
}
.tx:last-child { border-bottom: none; }

.tx-revoked .tx-sentence { color: #A3A9B0; }
.tx-system .tx-sentence { color: #6D7580; }

.tx-time {
  width: 80rpx;
  flex-shrink: 0;
  margin-right: 14rpx;
  color: #9AA1A9;
  font-size: 25rpx;
  font-weight: 400;
  font-variant-numeric: tabular-nums;
}

.tx-sentence {
  flex: 1;
  min-width: 0;
  color: #6D7580;
  font-weight: 400;
  white-space: normal;
  word-break: break-word;
}

/* 语义块间距：只用 margin，不写真实空格；数字与单位保持连续不断行 */
.tx-seg {
  display: inline-block;
  white-space: nowrap;
}
.tx-seg--operator { color: #7E858E; font-weight: 400; margin-right: 4rpx; }
.tx-seg--player { color: #3F4852; font-weight: 500; margin-right: 5rpx; }
.tx-seg--action { color: #6D7580; font-weight: 400; margin-right: 6rpx; }
.tx-seg--result { color: #505A65; font-weight: 500; }
.tx-seg--dim { color: #9AA1A9; font-weight: 400; margin-right: 4rpx; }
.tx-seg--revoked-suffix { color: #A3A9B0; font-weight: 400; margin-left: 8rpx; }

.expense-block {
  padding: 6rpx 0 12rpx;
}
.expense-head,
.expense-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.expense-head {
  min-height: 54rpx;
  margin-bottom: 8rpx;
}
.expense-title {
  flex-shrink: 0;
  font-size: 27rpx;
  font-weight: 700;
}
.expense-summary {
  overflow: hidden;
  color: var(--text-sub);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.expense-row {
  min-height: 54rpx;
  font-size: 24rpx;
  line-height: 54rpx;
}
.expense-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.expense-share {
  flex-shrink: 0;
  color: #b78b2f;
  font-weight: 600;
}
.expense-divider {
  height: 1rpx;
  background: var(--border);
  margin: 12rpx 0;
}

.ledger-title {
  margin: 30rpx 4rpx 14rpx;
}

.btn-tiny {
  flex-shrink: 0;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 16rpx;
  font-size: 22rpx;
}

.hands-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.hands-sheet {
  width: 580rpx;
  padding: 40rpx 40rpx 30rpx;
  border-radius: var(--radius-lg);
  background: #fff;
  box-sizing: border-box;
}

.hands-title {
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.hands-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  margin: 32rpx 0 18rpx;
}

.hands-step {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(43, 108, 176, 0.1);
  color: var(--table-green);
  font-size: 44rpx;
  font-weight: 700;
  text-align: center;
  line-height: 88rpx;
}

.hands-step.disabled { opacity: 0.4; }
.hands-step:active { background: rgba(43, 108, 176, 0.22); }

.hands-input {
  width: 168rpx;
  height: 88rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--table-green);
}

.hands-hint {
  text-align: center;
  font-size: 24rpx;
}

.hands-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.hands-btn {
  flex: 1;
  height: 80rpx;
  border-radius: var(--radius-md);
  text-align: center;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.hands-btn.cancel { background: rgba(0,0,0,0.05); color: var(--text-sub); }
.hands-btn.confirm { background: var(--table-green); color: #fff; }

.exclude-btn { font-size: 24rpx; color: var(--table-green); }

.quick-actions {
  display: flex;
  gap: 16rpx;
}

.quick-btn {
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 52rpx;
}

.quick-btn.primary {
  background: var(--table-green);
  color: #fff;
}

.quick-btn.ghost {
  background: rgba(0,0,0,0.05);
  color: var(--text);
}

.settle-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 16rpx 24rpx;
  margin-top: 0;
  font-size: 24rpx;
  background: rgba(0,0,0,0.03);
  border-top: 1rpx solid var(--border);
}

.settle-bar.ended {
  background: rgba(43,108,176,0.04);
  border-top: 1rpx solid rgba(43,108,176,0.1);
}

.bar-item {
  flex-shrink: 0;
}

.text-warning {
  color: #fa8c16;
}

.settle-summary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin: 20rpx 0 24rpx;
  padding: 22rpx 28rpx;
  background: #fff;
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(43, 108, 176, 0.08);
  box-shadow: 0 3rpx 12rpx rgba(24, 52, 82, 0.05);
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.summary-label {
  font-size: 20rpx;
  color: var(--text-sub);
  margin-bottom: 6rpx;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}

.summary-sep {
  width: 1rpx;
  height: 48rpx;
  background: rgba(0,0,0,0.08);
}

.check-text {
  color: var(--success);
  font-weight: 600;
}

.host-panel {
  margin-top: 24rpx;
}

.end-btn {
  text-align: center;
  width: 100%;
}

.game-sub-info {
  margin-bottom: 20rpx;
}

/* 顶栏双操作按钮 */
.info-actions { display: flex; gap: 12rpx; flex-shrink: 0; }

/* 费用分摊面板 */
.expense-mask {
  padding: 32rpx;
  box-sizing: border-box;
  background: rgba(16, 24, 32, 0.5);
}

.expense-sheet {
  width: 620rpx;
  max-width: 100%;
  padding: 38rpx 40rpx 34rpx;
  border-radius: var(--radius-lg);
  background: #fff;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.18);
  box-sizing: border-box;
}

.expense-modal-head {
  display: grid;
  grid-template-columns: 64rpx 1fr 64rpx;
  align-items: center;
}

.expense-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  color: var(--text-sub);
  font-size: 42rpx;
  line-height: 1;
}

.expense-close:active {
  opacity: 0.55;
}

.expense-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
}

.expense-head-spacer {
  width: 64rpx;
}

.expense-form {
  margin-top: 30rpx;
}

.expense-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 88rpx;
  border-bottom: 1rpx solid var(--border);
}

/* picker 内的分摊方式字段是最后一行，不再画线，避免与说明分隔线形成孤立双线 */
picker .expense-field {
  border-bottom: none;
}

.expense-field-label {
  flex-shrink: 0;
  color: var(--text);
  font-size: 27rpx;
  font-weight: 500;
}

.expense-amount-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  color: var(--text);
  font-size: 32rpx;
  text-align: right;
}

.expense-mode-value {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-width: 0;
  color: var(--text-sub);
  font-size: 29rpx;
}

.expense-mode-arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
}

.expense-compliance-note {
  margin-top: 18rpx;
  color: var(--text-sub);
  font-size: 22rpx;
}

.expense-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 32rpx;
}

.expense-button {
  height: 84rpx;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 84rpx;
  text-align: center;
}

.expense-button--cancel {
  background: #f2f4f7;
  color: var(--text-sub);
}

.expense-button--confirm {
  background: var(--table-green);
  color: #fff;
}

.expense-button--disabled {
  opacity: 0.55;
}
