.meta-row {
  display: flex; justify-content: space-between;
  padding: 20rpx 24rpx; background: var(--card);
  border-radius: var(--radius-md); margin-bottom: 16rpx; font-size: 26rpx;
}
.code { font-family: 'Courier New', monospace; font-weight: 600; color: var(--table-green); letter-spacing: 4rpx; }
.players { margin-bottom: 24rpx; }
.section-title { font-size: 26rpx; color: var(--text-sub); margin: 12rpx 8rpx; }
.host-actions { display: flex; gap: 16rpx; margin-bottom: 24rpx; flex-wrap: wrap; }
.host-actions .btn { flex: 1; min-width: 200rpx; }
.tx-list { padding: 16rpx 24rpx; }
.tx { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 0; border-bottom: 2rpx solid var(--border); }
.tx:last-child { border: none; }
.tx.revoked { opacity: 0.5; text-decoration: line-through; }
.tx-main { font-size: 26rpx; }
.tx-type { color: var(--text-sub); margin-right: 8rpx; }
.tx-name { font-weight: 500; margin-right: 8rpx; }
.tx-amount { color: var(--gold); font-weight: 600; }
.btn-tiny { height: 48rpx; line-height: 48rpx; padding: 0 16rpx; font-size: 22rpx; }
