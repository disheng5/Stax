<view class="container">
  <view class="grid">
    <view class="card stat"><view class="num">{{stats.totalGames}}</view><view class="text-sub">总场次</view></view>
    <view class="card stat"><view class="num text-gold">{{stats.totalProfit}}</view><view class="text-sub">累计盈亏</view></view>
    <view class="card stat"><view class="num text-success">{{stats.biggestWin}}</view><view class="text-sub">单局最大盈利</view></view>
    <view class="card stat"><view class="num text-danger">{{stats.biggestLoss}}</view><view class="text-sub">单局最大亏损</view></view>
    <view class="card stat"><view class="num">{{stats.winRate}}%</view><view class="text-sub">胜率</view></view>
  </view>
</view>
