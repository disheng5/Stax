.grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; margin-bottom: 16rpx; }
.stat { padding: 24rpx; text-align: center; margin: 0; }
.stat .num { font-size: 40rpx; font-weight: 700; margin-bottom: 6rpx; }
.title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; }
.dim-tabs { white-space: nowrap; margin-bottom: 16rpx; }
.dim-tab { display: inline-block; padding: 12rpx 24rpx; border-radius: 24rpx; background: var(--border); font-size: 24rpx; color: var(--text-sub); margin-right: 12rpx; }
.dim-tab.active { background: var(--table-green); color: #fff; }
.dim-table { font-size: 24rpx; }
.dim-head, .dim-row { display: flex; padding: 12rpx 0; border-bottom: 1rpx solid var(--border); }
.dim-head { font-weight: 500; }
.dim-row:last-child { border: none; }
.col-key { flex: 1.5; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.col { flex: 1; text-align: center; }
