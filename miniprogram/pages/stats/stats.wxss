.loading-hint { text-align: center; padding: 80rpx 0; }
.dim-tabs { white-space: nowrap; margin-bottom: 20rpx; }
.dim-tab { display: inline-block; padding: 12rpx 28rpx; border-radius: 24rpx; background: var(--border); font-size: 24rpx; color: var(--text-sub); margin-right: 12rpx; }
.dim-tab.active { background: var(--table-green); color: #fff; }
.dim-head, .dim-row { display: flex; padding: 14rpx 0; border-bottom: 1rpx solid var(--border); font-size: 24rpx; }
.dim-head { font-weight: 500; }
.dim-row:last-child { border: none; }
.col-key { flex: 1.5; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.col { flex: 1; text-align: center; }
