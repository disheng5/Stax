.invite-hero {
  padding: 44rpx 32rpx 38rpx;
  text-align: center;
}

.eyebrow {
  color: var(--table-green);
  font-size: 23rpx;
  font-weight: 600;
}

.game-name {
  overflow: hidden;
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.game-meta {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10rpx 22rpx;
  margin-top: 18rpx;
  color: var(--text-sub);
  font-size: 23rpx;
}

.primary-actions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.invite-state {
  margin-top: 18vh;
  padding: 56rpx 40rpx;
  text-align: center;
}

.state-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 22rpx;
  border-radius: var(--radius-sm);
  background: var(--table-green);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
}

.state-mark--muted {
  background: #dce3ec;
  color: var(--text-sub);
}

.state-title {
  font-size: 31rpx;
  font-weight: 700;
}

.state-note {
  margin-top: 10rpx;
  font-size: 23rpx;
}

.state-loading {
  width: 34rpx;
  height: 34rpx;
  margin: 30rpx auto 0;
  border: 4rpx solid rgba(43, 108, 176, 0.18);
  border-top-color: var(--table-green);
  border-radius: 50%;
  animation: loading-spin 0.8s linear infinite;
}

.back-button {
  margin-top: 34rpx;
}

@keyframes loading-spin {
  to { transform: rotate(360deg); }
}
