.invite-hero {
  text-align: center;
  padding: 44rpx 32rpx 36rpx;
}

.eyebrow {
  color: var(--text-sub);
  font-size: 24rpx;
}

.game-name {
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.game-meta {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 14rpx 22rpx;
  margin-top: 16rpx;
  color: var(--text-sub);
  font-size: 24rpx;
}

.invite-code {
  display: inline-block;
  margin-top: 26rpx;
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(11, 110, 79, 0.08);
  color: var(--table-green);
  font-family: 'Courier New', monospace;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
}

.label {
  margin-bottom: 12rpx;
  color: var(--text-sub);
  font-size: 26rpx;
}

.code-input {
  height: 110rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  background: #fff;
  font-family: 'Courier New', monospace;
  font-size: 52rpx;
  letter-spacing: 14rpx;
  text-align: center;
  box-sizing: border-box;
}

.lookup-state {
  margin-top: 14rpx;
  text-align: center;
  font-size: 24rpx;
}

.primary-actions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
